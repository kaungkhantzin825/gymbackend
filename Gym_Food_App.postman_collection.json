{
  "info": {
    "name": "Gym Food Calories App",
    "description": "Complete API collection for Gym Food Calories tracking app with FatSecret integration",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000/api"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\",\n  \"password_confirmation\": \"password123\"\n}"
            },
            "url": "{{base_url}}/register"
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{base_url}}/login"
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": "{{base_url}}/me"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": "{{base_url}}/logout"
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Get Today Summary",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": "{{base_url}}/dashboard"
          }
        },
        {
          "name": "Get Weekly Summary",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": "{{base_url}}/dashboard/weekly"
          }
        }
      ]
    },
    {
      "name": "Food Search",
      "item": [
        {
          "name": "Search Food",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {
              "raw": "{{base_url}}/food/search?query=chicken",
              "query": [{"key": "query", "value": "chicken"}]
            }
          }
        },
        {
          "name": "Get Food Details",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": "{{base_url}}/food/12345"
          }
        },
        {
          "name": "Search by Barcode",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"barcode\": \"012345678901\"\n}"
            },
            "url": "{{base_url}}/food/barcode"
          }
        },
        {
          "name": "Autocomplete",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {
              "raw": "{{base_url}}/food/autocomplete?query=chick",
              "query": [{"key": "query", "value": "chick"}]
            }
          }
        }
      ]
    },
    {
      "name": "Meals",
      "item": [
        {
          "name": "Get All Meals",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": "{{base_url}}/meals"
          }
        },
        {
          "name": "Create Meal",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Breakfast\",\n  \"meal_time\": \"2026-01-17 08:00:00\",\n  \"notes\": \"Healthy breakfast\"\n}"
            },
            "url": "{{base_url}}/meals"
          }
        },
        {
          "name": "Add Food to Meal",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"food_name\": \"Banana\",\n  \"serving_size\": 1,\n  \"serving_unit\": \"piece\",\n  \"calories\": 105,\n  \"protein\": 1.3,\n  \"carbs\": 27,\n  \"fat\": 0.4\n}"
            },
            "url": "{{base_url}}/meals/1/foods"
          }
        }
      ]
    },
    {
      "name": "Profile",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": "{{base_url}}/profile"
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Authorization", "value": "Bearer {{token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"age\": 25,\n  \"gender\": \"male\",\n  \"height\": 175,\n  \"current_weight\": 75,\n  \"target_weight\": 70,\n  \"goal\": \"lose_weight\",\n  \"activity_level\": \"moderate\"\n}"
            },
            "url": "{{base_url}}/profile"
          }
        },
        {
          "name": "Calculate Calories",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": "{{base_url}}/profile/calculate-calories"
          }
        }
      ]
    },
    {
      "name": "Exercises",
      "item": [
        {
          "name": "Get All Exercises",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": "{{base_url}}/exercises"
          }
        },
        {
          "name": "Create Exercise",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"exercise_name\": \"Running\",\n  \"exercise_type\": \"cardio\",\n  \"exercise_time\": \"2026-01-17 07:00:00\",\n  \"duration_minutes\": 30,\n  \"calories_burned\": 300\n}"
            },
            "url": "{{base_url}}/exercises"
          }
        }
      ]
    },
    {
      "name": "Weight Logs",
      "item": [
        {
          "name": "Get All Weight Logs",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": "{{base_url}}/weight-logs"
          }
        },
        {
          "name": "Create Weight Log",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"weight\": 75.5,\n  \"logged_at\": \"2026-01-17 08:00:00\",\n  \"notes\": \"Morning weight\"\n}"
            },
            "url": "{{base_url}}/weight-logs"
          }
        }
      ]
    }
  ]
}
